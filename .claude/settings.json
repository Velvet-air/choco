{
  "permissions": {
    "allow": [
      "Bash(bun run test *)",
      "Bash(bun run typecheck *)",
      "Bash(bun lint *)",
      "Bash(npx shadcn@latest *)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/lint-fix.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
